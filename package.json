{
  "name": "hermanos-landing-page",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-menu-data.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/generate-menu-data.mjs && node scripts/ai/check-tracking-events.mjs && node scripts/seo/check-phase-0-config.mjs",
    "build": "next build",
    "build:production": "node scripts/generate-menu-data.mjs && node scripts/ai/check-tracking-events.mjs && node scripts/seo/check-phase-0-config.mjs --production && next build",
    "start": "next start",
    "menu:generate": "node scripts/generate-menu-data.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "npm run test:unit",
    "test:unit": "playwright test --config=playwright.unit.config.ts --project=unit",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:chromium": "playwright test --project=chromium",
    "screenshots": "playwright test --config=playwright.screenshots.config.ts --project=screenshots",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e",
    "ai:validate-context": "node scripts/ai/validate-context.mjs",
    "ai:index": "node scripts/ai/generate-agent-index.mjs",
    "ai:route": "node scripts/ai/resolve-agent-route.mjs",
    "ai:check-tracking": "node scripts/ai/check-tracking-events.mjs",
    "ai:check-seo": "node scripts/ai/check-seo-files.mjs",
    "seo:check-phase0": "node scripts/seo/check-phase-0-config.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.45.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.81.0",
    "resend": "^6.17.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
